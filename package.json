{
  "name": "hospitality-network",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "npm run start --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "db:migrate": "npm run migrate --workspace=packages/database",
    "db:generate": "npm run generate --workspace=packages/database",
    "db:seed": "npm run seed --workspace=packages/database"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "turbo": "^2.0.0",
    "webpack": "^5.107.2"
  }
}
