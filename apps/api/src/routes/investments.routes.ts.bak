import { Router, Request, Response } from "express";
import { prisma } from "@hospitality/database";
import { authenticate, authorize } from "../middleware/auth";
import { slugify } from "../utils/slugify";

const router = Router();

// POST /api/investments - Create opportunity
router.post("/", authenticate, authorize("OWNER", "SUPER_ADMIN"), async (req: Request, res: Response) => {
  try {
    const { title, type, description, city, state, askingPrice, investmentRange, rooms, propertyType, hotelId, images } = req.body;
    const slug = slugify(title) + "-" + Date.now().toString(36);

    const investment = await prisma.investmentOpportunity.create({
      data: {
        title, slug, type, description, city, state, askingPrice,
        investmentRange, rooms, propertyType, hotelId,
        images: images || [], documents: [],
        authorId: req.user!.userId,
      },
    });
    return res.status(201).json(investment);
  } catch (error) {
    return res.status(500).json({ error: "Failed to create investment" });
  }
});

// GET /api/investments - List
router.get("/", async (req: Request, res: Response) => {
  try {
    const { type, city, state, search, page = "1", limit = "20" } = req.query;
    const skip = (parseInt(page as string) - 1) * parseInt(limit as string);

    const where: any = { isActive: true };
    if (type) where.type = type;
    if (city) where.city = { contains: city as string, mode: "insensitive" };
    if (state) where.state = { contains: state as string, mode: "insensitive" };
    if (search) where.title = { contains: search as string, mode: "insensitive" };

    const [investments, total] = await Promise.all([
      prisma.investmentOpportunity.findMany({
        where,
        include: {
          author: { select: { id: true, firstName: true, lastName: true, avatar: true } },
          hotel: { select: { id: true, name: true, city: true, state: true } },
        },
        skip,
        take: parseInt(limit as string),
        orderBy: { createdAt: "desc" },
      }),
      prisma.investmentOpportunity.count({ where }),
    ]);

    return res.json({ investments, total, page: parseInt(page as string), totalPages: Math.ceil(total / parseInt(limit as string)) });
  } catch (error) {
    return res.status(500).json({ error: "Failed to fetch investments" });
  }
});

// GET /api/investments/:id
router.get("/:id", async (req: Request, res: Response) => {
  try {
    const investment = await prisma.investmentOpportunity.findUnique({
      where: { id: req.params.id },
      include: {
        author: { select: { id: true, firstName: true, lastName: true, avatar: true, title: true } },
        hotel: { select: { id: true, name: true, city: true, state: true, rooms: true, starRating: true } },
      },
    });
    if (!investment) return res.status(404).json({ error: "Investment not found" });
    return res.json(investment);
  } catch (error) {
    return res.status(500).json({ error: "Failed to fetch investment" });
  }
});

// PUT /api/investments/:id
router.put("/:id", authenticate, async (req: Request, res: Response) => {
  try {
    const investment = await prisma.investmentOpportunity.findUnique({ where: { id: req.params.id } });
    if (!investment || (investment.authorId !== req.user!.userId && req.user!.role !== "SUPER_ADMIN")) {
      return res.status(403).json({ error: "Not authorized" });
    }
    const updated = await prisma.investmentOpportunity.update({ where: { id: req.params.id }, data: req.body });
    return res.json(updated);
  } catch (error) {
    return res.status(500).json({ error: "Failed to update investment" });
  }
});

// DELETE /api/investments/:id
router.delete("/:id", authenticate, async (req: Request, res: Response) => {
  try {
    const investment = await prisma.investmentOpportunity.findUnique({ where: { id: req.params.id } });
    if (!investment || (investment.authorId !== req.user!.userId && req.user!.role !== "SUPER_ADMIN")) {
      return res.status(403).json({ error: "Not authorized" });
    }
    await prisma.investmentOpportunity.update({ where: { id: req.params.id }, data: { isActive: false } });
    return res.json({ deleted: true });
  } catch (error) {
    return res.status(500).json({ error: "Failed to delete investment" });
  }
});

export default router;
